# FastAPI Backend environment configuration template

# Running mode: development, production, testing
FASTAPI_ENV=development

# Relative or absolute path where the tumor and severity PyTorch models are stored
MODEL_PATH=./models/

# Debug mode flag (enables trace logs and Swagger endpoints)
DEBUG=true

# Allowed CORS origins, comma-separated list of frontends allowed to query the API
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:5173
