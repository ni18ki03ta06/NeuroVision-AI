# ==============================================================================
# NeuroVision AI — Git Exclusions (.gitignore)
# ==============================================================================

# ------------------------------------------------------------------------------
# Python (Backend)
# ------------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
.venv/
env/
ENV/
.env

# ------------------------------------------------------------------------------
# Node & React (Frontend)
# ------------------------------------------------------------------------------
node_modules/
.env.local
.env.*.local
build/
dist/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ------------------------------------------------------------------------------
# IDEs & Editors
# ------------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace

# ------------------------------------------------------------------------------
# Operating System Files
# ------------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ------------------------------------------------------------------------------
# Project Specific Exclusions
# ------------------------------------------------------------------------------
.cache/
.pytest_cache/
*.pth
*.pdf
*.db
backend/predictions.db
backend/tests/test_predictions.db
temp/
data/
models/
results/


# ------------------------------------------------------------------------------
# Explicitly Keep / Track Configuration Files
# ------------------------------------------------------------------------------
!requirements.txt
!package.json
!.env.example
