# API configuration variables for Vite/React frontend
# Note: Since the project uses Vite, REACT_APP_ prefixed variables are supported 
# by configuring envPrefix in vite.config.js.

# URL endpoint of the FastAPI backend service
REACT_APP_API_BASE_URL=http://localhost:8000/api

# Axios timeout in milliseconds (30000 = 30 seconds for TTA inference runs)
REACT_APP_API_TIMEOUT=30000

# Environment state
REACT_APP_ENVIRONMENT=development
